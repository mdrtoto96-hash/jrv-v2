# ============================================================
# JRV V2 — Variables d'environnement
# Copie ce fichier en .env.local pour le dev local (vercel dev)
# En production : Vercel Dashboard > Settings > Environment Variables
# NE JAMAIS committer un fichier avec de vraies valeurs !
# ============================================================

# Clé API Anthropic (récupérer sur console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Mot de passe de connexion au site (choisis-le toi-même)
APP_PASSWORD=monMotDePasseSecret

# Secret JWT pour signer les sessions (génère une chaîne aléatoire longue)
# Exemple : openssl rand -base64 32
JWT_SECRET=une-chaine-aleatoire-tres-longue-et-secrete

# Pour tester en local avec les agents IA :
# 1. Installe Vercel CLI : npm i -g vercel
# 2. Lance : vercel dev  (au lieu de python3 -m http.server)
# 3. Site sur http://localhost:3000 avec /api/* actif
